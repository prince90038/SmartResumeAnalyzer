# Hosted Hugging Face inference (default)
HF_BACKEND=endpoint
HF_TOKEN=hf_your_token
HF_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Generation settings
HF_MAX_NEW_TOKENS=2048

# Fully local alternative (downloads the model on first use)
# HF_BACKEND=local
# HF_LOCAL_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# HF_LOCAL_DEVICE=-1

# Embedding model used for skill matching
HF_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
